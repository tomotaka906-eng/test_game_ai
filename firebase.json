{
  "hosting": {
    "public": ".",
    "headers": [
      {
        "source": "/sw.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      }
    ],
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".gitignore",
      ".git",
      "**/node_modules/**"
    ]
  }
}
