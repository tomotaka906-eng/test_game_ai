{
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": ".",
    "headers": [
      {
        "source": "/sw.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "**",
        "headers": [
          { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; manifest-src 'self'; connect-src 'self' https://test-game-ai-default-rtdb.firebaseio.com; frame-ancestors 'none'; base-uri 'self'; object-src 'none'" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "Referrer-Policy", "value": "no-referrer" },
          { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" }
        ]
      }
    ],
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".gitignore",
      ".git",
      "database.rules.json",
      "**/node_modules/**"
    ]
  }
}
