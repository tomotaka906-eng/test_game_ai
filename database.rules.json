{
  "rules": {
    ".read": false,
    ".write": false,
    "scores": {
      "$game": {
        ".read": true,
        ".indexOn": ["score"],
        "$entry": {
          ".write": "!data.exists() && newData.exists()",
          ".validate": "newData.hasChildren(['name', 'score', 'ts'])",
          "name": {
            ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 12"
          },
          "score": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000000"
          },
          "ts": {
            ".validate": "newData.isNumber() && newData.val() > 0"
          },
          "$other": {
            ".validate": false
          }
        }
      }
    }
  }
}
